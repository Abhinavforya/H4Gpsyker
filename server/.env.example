SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
# Example: http://localhost:8888/auth/callback or https://<your-ngrok>.ngrok.io/auth/callback
REDIRECT_URI=http://localhost:8888/auth/callback
PORT=8888
# Optional: set NGROK_URL if using ngrok for local development
# NGROK_URL=https://<your-ngrok>.ngrok.io
